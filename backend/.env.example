# =============================================================================
# RESUME ANALYZER API — ENVIRONMENT TEMPLATE
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values in .env
#   3. Never commit .env to version control (it is already in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Display name for the API (shown in /docs)
APP_NAME="Resume Analyzer API"

# Semantic version of the running build
APP_VERSION="5.0.0"

# Set to true only in local development — enables verbose error traces
DEBUG=false

# Maximum allowed resume file size in megabytes
MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# AI FEEDBACK LAYER — Google AI Studio (Gemini)
# -----------------------------------------------------------------------------
# Purpose  : Powers the AI-generated resume feedback (summary, strengths,
#            weaknesses, ATS tips, career level, role recommendations).
# Provider : Google AI Studio — free tier available
# Model    : gemini-2.0-flash
# Get key  : https://aistudio.google.com/app/apikey
#
# Leave blank or omit to disable AI feedback entirely.
# The core scoring engine (OCR + NLP + deterministic analysis) continues
# to work with full accuracy regardless of this setting.
# -----------------------------------------------------------------------------
AI_API_KEY=your_google_ai_studio_key_here

# -----------------------------------------------------------------------------
# MONGODB — Resume history storage
# -----------------------------------------------------------------------------
# Purpose  : Persists every analysis result to a 'resumes' collection so you
#            can query history by user name or resume id.
# Provider : MongoDB Atlas (free M0 cluster is sufficient)
# Note     : Special characters in the password must be URL-encoded.
#              @ → %40    # → %23    : → %3A
# Example  : mongodb+srv://user:p%40ss@cluster0.example.mongodb.net/resume_analyzer?appName=Cluster0
#
# Leave blank or omit to disable storage (analysis still works fully).
# -----------------------------------------------------------------------------
MONGODB_URI=your_mongodb_connection_string_here

# -----------------------------------------------------------------------------
# CORS — Allowed frontend origins (production)
# -----------------------------------------------------------------------------
# Purpose  : Restricts which domains may call the API.
#            In production, set this to your Vercel frontend URL(s).
#            Comma-separate multiple URLs — no spaces around commas.
#            Leave BLANK in local development — defaults to allow all origins.
# Examples :
#   Single  : FRONTEND_URL=https://resume-insight-engine.vercel.app
#   Multiple: FRONTEND_URL=https://resume-insight-engine.vercel.app
# Localhost origins (5173, 3000) are always added automatically for dev use.
# -----------------------------------------------------------------------------
FRONTEND_URL=https://resume-insight-engine.vercel.app
