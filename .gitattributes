# Normalize line endings across all operating systems.
# This stops the "LF will be replaced by CRLF" warnings on Windows.

# Default: normalize all text files to LF in the repo; checkout as native
* text=auto eol=lf

# Force LF for source files regardless of OS
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.txt  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf

# Binary — never touch these
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
